<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow layer -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/glow_blue" />
            <padding android:bottom="12dp" android:top="12dp" android:left="12dp" android:right="12dp"/>
        </shape>
    </item>
    <!-- Core circle -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/dark_charcoal" />
            <stroke android:width="2dp" android:color="@color/stroke_blue_grey" />
        </shape>
    </item>
</layer-list>
